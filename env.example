# =============================================================================
# Healthcare ML Portfolio - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# General Settings
# =============================================================================
COMPOSE_PROJECT_NAME=healthcare-ml-portfolio
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# MongoDB Configuration
# =============================================================================
# Local development
MONGO_URI=mongodb://mongodb:27017/
MONGO_DB_HSE=HSE
MONGO_DB_MIMIC=mimic
MONGO_DB_RECOMMENDER=recommender_system

# For production (external MongoDB)
# MONGO_URI=mongodb://username:password@host:port/

# =============================================================================
# Service Ports (internal)
# =============================================================================
PULSEFLOW_PORT=8001
CAREPLANPLUS_PORT=8002
PULSENOTES_PORT=8003
MEDISYNC_PORT=8004

# =============================================================================
# MLflow Configuration
# =============================================================================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts

# =============================================================================
# MinIO (S3-compatible storage)
# =============================================================================
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret_password_change_me
MINIO_ENDPOINT=minio:9000
AWS_ACCESS_KEY_ID=minio_admin
AWS_SECRET_ACCESS_KEY=minio_secret_password_change_me

# =============================================================================
# Redis (caching)
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Model Paths
# =============================================================================
PULSEFLOW_MODEL_PATH=/app/models/lstm_model.pth
CAREPLANPLUS_MODEL_PATH=/app/models/bert_model.pth
PULSENOTES_MODEL_PATH=/app/models/clinicalbert
MEDISYNC_MODEL_PATH=/app/models/maddpg_checkpoint.pth

# =============================================================================
# GPU Configuration
# =============================================================================
# Set to 'cpu' for CPU-only inference
DEVICE=cpu
# For GPU: DEVICE=cuda

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Monitoring
# =============================================================================
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# =============================================================================
# Docker Hub (for CI/CD)
# =============================================================================
DOCKER_REGISTRY=harishankarsomasundaram
DOCKER_USERNAME=harishankarsomasundaram
# DOCKER_PASSWORD should be set in GitHub Secrets, not here

# =============================================================================
# GCP VM Deployment
# =============================================================================
GCP_VM_HOST=your-vm-ip-or-hostname
GCP_VM_USER=deploy
# SSH key should be configured separately

# =============================================================================
# Domain & SSL (Production)
# =============================================================================
DOMAIN=localhost
SSL_EMAIL=your-email@example.com
