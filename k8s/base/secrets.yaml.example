# Kubernetes Secret template — COPY THIS, DO NOT COMMIT THE COPY.
#
#   cp k8s/base/secrets.yaml.example k8s/base/secrets.yaml
#   # edit with real values (or use `kubectl create secret generic ... --from-env-file`)
#
# Preferred for production: inject real secrets via a controller such as
# External Secrets Operator, SealedSecrets, or GKE Secret Manager CSI driver,
# never check them into source control.
apiVersion: v1
kind: Secret
metadata:
  name: hse-pulse-secrets
  namespace: hse-pulse
type: Opaque
stringData:
  MINIO_ROOT_USER: "REPLACE_ME"
  MINIO_ROOT_PASSWORD: "REPLACE_ME"
  GF_SECURITY_ADMIN_PASSWORD: "REPLACE_ME"
---
apiVersion: v1
kind: Secret
metadata:
  name: mongodb-secrets
  namespace: hse-pulse
type: Opaque
stringData:
  MONGO_INITDB_ROOT_USERNAME: "REPLACE_ME"
  MONGO_INITDB_ROOT_PASSWORD: "REPLACE_ME"
